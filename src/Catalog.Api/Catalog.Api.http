PUT {{Catalog.Api_HostAddress}}/{{Catalog.Api_version}}/products/{id}
Content-Type: application/json

{
  "name": "Updated name",
  "description": "Updated description",
  "price": 99.99
}
###

DELETE {{Catalog.Api_HostAddress}}/{{Catalog.Api_version}}/products/{id}
